# Copy to frontend/.env for local dev.
# Vercel: Project → Environment Variables. Redeploy after changing VITE_* (build-time).

VITE_API_URL=http://localhost:8000
# Same Web Client ID as backend GOOGLE_CLIENT_ID (Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=
