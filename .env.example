# Copy to .env and fill values (do not commit secrets).

PROJECT_NAME=BeautyTask

# --- Database (local docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=beautytask_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=beautytask_db

# --- App security ---
SECRET_KEY=CHANGE_ME

# --- Access control (optional) ---
# Comma-separated emails for Google login allowlist. Leave unset or empty on
# production to allow any user that already exists in the database.
# ALLOWED_EMAILS=you@example.com,other@example.com

# --- Mail (FastAPI-Mail) ---
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# --- Google OAuth2 (Calendar Connect) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/calendar/callback
FRONTEND_URL=http://localhost:5173

# Optional flags
# DEFAULT_TIMEZONE=Europe/Madrid
# ENABLE_COEP_REQUIRE_CORP=false
