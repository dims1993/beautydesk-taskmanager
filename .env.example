# Copy to .env and fill values (do not commit secrets).

PROJECT_NAME=BeautyTask

# --- Database ---
# Local: use POSTGRES_* below; leave DATABASE_URL unset.
# Render: set DATABASE_URL on the Web Service from Postgres → External Database URL
# (host must be dpg-xxx.REGION-postgres.render.com). postgres:// is rewritten to postgresql://.
# DATABASE_URL=postgresql://USER:PASS@dpg-xxxx.us-east-1-postgres.render.com/DBNAME
POSTGRES_USER=postgres
POSTGRES_PASSWORD=beautytask_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=beautytask_db

# --- App security ---
SECRET_KEY=CHANGE_ME

# Solo registro SUPER_ADMIN: misma clave en el formulario y aquí (producción: valor largo y secreto).
# Si está vacío, nadie puede registrarse como SUPER_ADMIN.
# SUPER_ADMIN_REGISTRATION_SECRET=

# --- CORS (Vercel or any separate frontend) ---
# Comma-separated origins, no trailing slashes. Set on Render Web Service.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-app.vercel.app

# --- Access control (optional) ---
# Comma-separated emails for Google login allowlist. Leave unset or empty on
# production to allow any user that already exists in the database.
# ALLOWED_EMAILS=you@example.com,other@example.com

# --- Mail (FastAPI-Mail) ---
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# --- Google OAuth2 (Calendar Connect) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/calendar/callback
FRONTEND_URL=http://localhost:5173

# Optional flags
# DEFAULT_TIMEZONE=Europe/Madrid
# ENABLE_COEP_REQUIRE_CORP=false
