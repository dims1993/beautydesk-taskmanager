# Copy to .env and fill values (do not commit secrets).

PROJECT_NAME=BeautyTask

# --- Database (local docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=beautytask_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=beautytask_db

# --- App security ---
SECRET_KEY=CHANGE_ME

# --- Access control ---
ALLOWED_EMAILS=dimsepp@gmail.com,testingsaasnow@gmail.com

# --- Mail (FastAPI-Mail) ---
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com

# --- Google OAuth2 (Calendar Connect) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/calendar/callback
FRONTEND_URL=http://localhost:5173

# Optional flags
# DEFAULT_TIMEZONE=Europe/Madrid
# ENABLE_COEP_REQUIRE_CORP=false
